#!/usr/bin/env python3
"""zu-render — the tier-2 one-shot render entrypoint, run inside the container.

The ``local-docker`` backend execs ``zu-render <url> [flags]`` and reads one JSON
line from stdout: ``{"status","html","text","url"}`` (+ ``network``/``content``
when capturing) — the same observation shape ``http_fetch`` produces, so the loop
and detectors stay tool-agnostic. It renders the URL in headless Chromium (JS
executed), and can WAIT for late-injected content, run read-surfacing ACTIONS, and
CAPTURE the network responses a widget fetches its data from. All generic — the
shared primitives live in ``_browser_session`` (also used by the persistent
``zu-browser`` session server).

Chromium runs with ``--no-sandbox`` on purpose: the *container* is the sandbox
(caps dropped, no-new-privileges), so Chromium's own setuid sandbox is not the
boundary here.
"""

from __future__ import annotations

import argparse
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))  # import the sibling lib

from _browser_session import (  # noqa: E402
    _ACTION_TIMEOUT_MS,
    _LAUNCH_ARGS,
    _WAIT_UNTIL,
    _attach_network_capture,
    _run_actions,
    _visible_text,
    launch_page,
)


def main() -> int:
    parser = argparse.ArgumentParser(prog="zu-render", add_help=False)
    parser.add_argument("url", nargs="?", default="")
    parser.add_argument("--width", type=int, default=1280)
    parser.add_argument("--height", type=int, default=720)
    parser.add_argument("--wait-until", default="load", choices=_WAIT_UNTIL)
    parser.add_argument("--wait-for", default=None)
    parser.add_argument("--wait-ms", type=int, default=0)
    parser.add_argument("--actions", default=None)
    parser.add_argument("--capture-network", action="store_true")
    args = parser.parse_args(sys.argv[1:])
    url = args.url
    if not url:
        print(json.dumps({"status": 400, "html": "", "error": "usage: zu-render <url> [flags]"}))
        return 2
    try:
        actions = json.loads(args.actions) if args.actions else []
        if not isinstance(actions, list):
            raise ValueError("--actions must be a JSON list")
    except (ValueError, json.JSONDecodeError) as exc:
        print(json.dumps({"status": 400, "html": "", "url": url, "error": f"bad --actions: {exc}"}))
        return 2
    try:
        from playwright.sync_api import sync_playwright

        with sync_playwright() as p:
            browser = p.chromium.launch(args=_LAUNCH_ARGS)
            action_error = None
            try:
                page = launch_page(browser, args.width, args.height)
                captured: list = []
                if args.capture_network:
                    _attach_network_capture(page, captured)
                resp = page.goto(url, wait_until=args.wait_until, timeout=30000)
                status = resp.status if resp is not None else 200
                if args.wait_for:
                    page.wait_for_selector(args.wait_for, timeout=_ACTION_TIMEOUT_MS)
                if actions:
                    action_error = _run_actions(page, actions)
                if args.wait_ms:
                    page.wait_for_timeout(min(args.wait_ms, _ACTION_TIMEOUT_MS))
                html = page.content()
                text = _visible_text(page)
            finally:
                browser.close()
        out = {"status": status, "html": html, "text": text, "url": url}
        if captured:
            out["network"] = captured
            out["content"] = "\n\n".join(
                f"# {c['url']} ({c['status']})\n{c['body']}" for c in captured
            )
        if action_error:
            out["action_error"] = action_error
        print(json.dumps(out))
        return 0
    except Exception as exc:  # noqa: BLE001 - report as an observation, never crash
        print(json.dumps({"status": 500, "html": "", "url": url, "error": f"{type(exc).__name__}: {exc}"}))
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

# Copy to .env (gitignored) and fill in. The bundle's .env is loaded for the run
# and mounted with the bundle when --sandboxed, so config names the env var
# (api_key_env) and never the key itself.
EXA_API_KEY=your-exa-key            # web_search (the Exa connector) — exa.ai
ANTHROPIC_API_KEY=your-model-key    # the model the agent runs on

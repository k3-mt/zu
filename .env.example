# Copy to .env and fill in. Secrets are read from the environment inside each
# provider adapter — never placed in the model's context or in config files.
# (.env is gitignored.)

# Anthropic (the `anthropic` provider)
ANTHROPIC_API_KEY=

# OpenAI / OpenRouter / local — all via the `openai-compatible` provider.
# Point the base URL at the endpoint you want; the same adapter reaches all.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local models (Ollama / vLLM) usually need no key:
# OPENAI_BASE_URL=http://localhost:11434/v1

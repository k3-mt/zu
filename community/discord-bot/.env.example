# Copy to .env and fill in. Never commit the real .env.

# Required: the bot token from the Discord Developer Portal
#   (Applications -> your app -> Bot -> Reset Token).
DISCORD_BOT_TOKEN=

# Optional: a server (guild) id for instant slash-command registration during
# development. Leave unset in production so commands register globally.
GUILD_ID=

# Optional: which channel Zeke greets new members in (default: general).
WELCOME_CHANNEL=
